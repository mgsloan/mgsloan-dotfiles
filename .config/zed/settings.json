{
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "cli_default_open_behavior": "existing_window",
  "edit_predictions": {
    "provider": "zed",
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "preferred_completion_mode": "burn",
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4",
    },
    "default_profile": "write",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6-latest",
    },
  },
  "profiles": {
    "big-screen": {
      "settings": {
        "ui_font_size": 7.0,
        "buffer_font_size": 7.0,
      },
    },
  },
  "ui_font_size": 13.0,
  "buffer_font_size": 13.0,
  "buffer_font_family": "Hack",
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Ayu Dark",
  },
  "current_line_highlight": "none",
  "cursor_blink": false,
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "targetDir": "target/analyzer/",
        },
        "check": {
          "command": "clippy",
        },
        "completion": {
          "postfix": {
            "enable": false,
          },
        },
        "assist": {
          "preferSelf": false,
        },
        "typing": {
          "triggerChars": "",
        },
        "numThreads": 8,
      },
    },
  },
  "dev": {
    "experimental.theme_overrides": {
      "title_bar.background": "#332429",
    },
  },
  // Used by mgsloan's custom dogfood builds, not an official Zed thing.
  "dogfood": {
    "experimental.theme_overrides": {
      "title_bar.background": "#24332e",
    },
  },
  "stable": {
    "experimental.theme_overrides": {
      "title_bar.background": "#000000",
    },
  },
  "languages": {
    "Rust": {
      "preferred_line_length": 100,
      "remove_trailing_whitespace_on_save": true,
    },
    "TOML": {
      "formatter": "prettier",
      "prettier": {
        "allowed": true,
      },
    },
    "Markdown": {
      "soft_wrap": "bounded",
      "show_edit_predictions": false,
      "remove_trailing_whitespace_on_save": true,
    },
    "Plain Text": {
      "soft_wrap": "bounded",
      "show_edit_predictions": false,
      "remove_trailing_whitespace_on_save": true,
    },
    "JSON": {
      "use_autoclose": true,
    },
    "JavaScript": {
      "format_on_save": "off",
    },
  },
  "use_autoclose": false,
  "calls": {
    "mute_on_join": true,
  },
  "show_signature_help_after_edits": true,
  "confirm_quit": true,
  "tab_bar": {
    "show": false,
  },
  "gutter": {
    "line_numbers": false,
    "runnables": false,
    "folds": false,
    "breakpoints": false,
  },
  /*
  "scrollbar": {
    "search_results": false,
    "diagnostics": "none",
    "selected_symbol": false
  },
  */
  "scrollbar": {
    "show": "never",
  },
  "title_bar": {
    "show_user_picture": false,
  },
  "outline_panel": {
    "indent_size": 14,
  },
  "project_panel": {
    "indent_size": 14,
  },
  "toolbar": {
    "quick_actions": false,
  },
  "load_direnv": "direct",
  "use_system_path_prompts": false,
  "inline_code_actions": false,
  "buffer_line_height": { "custom": 1.3 },
}
